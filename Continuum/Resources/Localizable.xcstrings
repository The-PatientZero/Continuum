    "This will reset all settings to their default values. This action cannot be undone." : {
      "comment" : "A message displayed in an alert when the user confirms resetting all settings.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tím se všechna nastavení vrátí na výchozí hodnoty. Tuto akci nelze vrátit zpět."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies wird alle Einstellungen auf ihre Standardwerte zurücksetzen. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto restablecerá todos los ajustes a sus valores predeterminados. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela réinitialisera tous les réglages à leurs valeurs par défaut. Cette action est irréversible."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ez minden beállítást visszaállít az alapértelmezett értékére. Ez a művelet nem vonható vissza."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opsi ini akan mengatur ulang semua pengaturan ke pengaturan bawaan. Tindakan ini tidak dapat dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa operazione ripristinerà tutte le impostazioni ai valori predefiniti. Questa azione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての設定をデフォルト値にリセットします。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 설정을 기본값으로 재설정합니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdoor worden alle instellingen teruggezet naar hun standaardwaarden. Deze handeling kan niet ongedaan worden gemaakt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spowoduje to przywrócenie wszystkich ustawień do ich wartości domyślnych. Tej operacji nie można cofnąć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso redefinirá todas as configurações para os valores padrão. Esta ação não pode ser desfeita."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все настройки будут сброшены до значений по умолчанию. Это действие нельзя отменить."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การดำเนินการนี้จะรีเซ็ตการตั้งค่าทั้งหมดเป็นค่าเริ่มต้น ไม่สามารถเลิกทำได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu işlem tüm ayarları varsayılan değerlerine sıfırlayacaktır. Bu işlem geri alınamaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Усі налаштування буде скинуто до типових значень. Цю дію неможливо скасувати."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Điều này sẽ đặt lại tất cả các cài đặt về giá trị mặc định của chúng. Không thể hoàn tác hành động này."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将所有设置重置为默认值。此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此操作將把所有設定重置為預設值。此操作無法復原。"
          }
        }
      }
    },
