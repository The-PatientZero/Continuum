    "The %@ Bar is centered below the %@ icon." : {
      "comment" : "A description of the location of the Overlay Tray when it is displayed below the control icon.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lišta %@ je vystředěná pod ikonou %@."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die %1$@-Leiste wird unter dem %2$@-Symbol zentriert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barra de %1$@ se centra debajo del icono de %2$@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La « %1$@ Bar » est centrée sous l'icône %2$@."
