    "Reset completed with %lld item(s) that could not be moved. Check the menu bar and try again if needed." : {
      "comment" : "A message describing the result of a menu bar layout reset, including the number of items that could not be moved.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obnovení bylo dokončeno. %lld položek se nepodařilo přesunout. Zkontrolujte řádek nabídek a v případě potřeby to zkuste znovu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zurücksetzen abgeschlossen, %lld Einträge konnten nicht bewegt werden. Menüleiste überprüfen und gegebenenfalls erneut versuchen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restablecimiento completado con %lld elemento(s) que no se pudieron mover. Revisa la barra de menús y vuelve a intentarlo si es necesario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réinitialisation terminée, %lld élément(s) n'ont pas pu être déplacé(s). Vérifiez la barre des menus et réessayez si nécessaire."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visszaállítás befejezve, %lld elem nem volt mozgatható. Ellenőrizze a menüsort, és szükség esetén próbálja újra."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pengaturan ulang berhasil dengan item %lld yang tidak dapat dipindahkan. Periksa bar menu lalu coba lagi jika perlu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reimpostazione completata con %lld elementi che non è stato possibile spostare. Controlla la barra dei menu e riprova se necessario."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リセットが完了しましたが、%lld 個の項目を移動できませんでした。必要に応じてメニューバーを確認し、再試行してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld개 항목을 이동할 수 없어 재설정이 완료되었습니다. 메뉴 막대를 확인하고 필요한 경우 다시 시도하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reset voltooid met %lld item(s) dat/die niet kon/konden worden verplaatst. Controleer de menubalk en probeer het indien nodig opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resetowanie zakończone. Liczba elementów, których nie udało się przenieść: %lld. Sprawdź pasek menu i spróbuj ponownie w razie potrzeby."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A redefinição foi concluída com %lld item(ns) que não puderam ser movidos. Verifique a barra de menus e tente novamente, se necessário."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сброс завершён, но %lld элемент(ов) не удалось переместить. Проверьте строку меню и повторите при необходимости."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "รีเซ็ตเสร็จสิ้น แต่มีรายการ %lld รายการที่ไม่สามารถย้ายได้ โปรดตรวจสอบแถบเมนูและลองทำอีกครั้งหากจำเป็น"
          }
