            "value" : "Always show hidden menu bar items in the menu bar."
          }
        }
      }
    },
    "Always show the %@ Bar at the mouse pointer's location when it is shown using a hotkey." : {
      "comment" : "A toggle that lets users decide whether the location of the \\(Constants.displayName) Bar should be fixed at the mouse pointer's location when it is shown using a hotkey.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vždy zobrazit lištu %@ v místě kurzoru myši, pokud je vyvolána pomocí klávesové zkratky."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die %@-Leiste immer an der Position des Mauszeigers anzeigen, wenn ein Tastaturkürzel benutzt wird."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostrar siempre la barra de %@ en la posición del cursor cuando se activa con un atajo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toujours afficher la « %@ Bar » à l'emplacement du pointeur de la souris lorsqu'elle est affichée à l'aide d'un raccourci clavier."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mindig jelenjen meg a %@ sáv az egérmutató helyén, amikor gyorsbillentyűvel jeleníted meg."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selalu tampilkan Bar %@ di posisi penunjuk saat ditampilkan dengan pintasan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra sempre la barra ￼ nella posizione del puntatore del %@mouse quando viene visualizzata tramite un tasto di scelta rapida."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホットキーで表示する際は、%@ バーを常にマウスポインターの位置に表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "단축키로 표시할 때 %@ 막대를 항상 마우스 포인터 위치에 표시합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geef de %@-balk altijd weer op de plek van de muisaanwijzer wanneer deze met een sneltoets wordt weergegeven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zawsze pokazuj pasek %@ w miejscu kursora myszy, gdy jest on wywoływany skrótem klawiszowym."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sempre mostrar a Barra %@ na posição do ponteiro do mouse quando ela for exibida usando um atalho."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Всегда показывать панель %@ у указателя мыши при вызове горячей клавишей."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แสดงแถบ %@ ไว้ที่ตำแหน่งของตัวชี้เมาส์เสมอเมื่อแสดงโดยใช้ปุ่มลัด"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kısayol tuşuyla gösterildiğinde %@ Çubuğunu her zaman fare imlecinin konumunda göster."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Завжди показувати %@ Bar у місці розташування курсора миші, коли його викликано гарячою клавішею."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Luôn hiển thị Thanh %@ tại vị trí con trỏ chuột khi nó được hiển thị bằng phím tắt."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用热键时，始终将 %@ 栏显示在鼠标指针的位置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用快速鍵顯示 %@ 列時，一律在滑鼠游標所在位置顯示。"
          }
        }
      }
    },
