    "Hover over an empty area of the menu bar to show hidden menu bar items." : {
      "comment" : "Text displayed in a toggle that allows the user to enable or disable the feature of showing hidden menu bar items by hovering over an empty area of the menu bar.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přejděte kurzorem myši nad prázdnou část řádku nabídek, aby se zobrazily skryté položky."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Über einem leeren Bereichen der Menüleiste schweben, um versteckte Menüleisten-Einträge anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pasa el cursor sobre un área vacía de la barra de menús para mostrar los elementos ocultos de la barra de menús."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Survolez une zone vide de la barre des menus pour afficher les éléments masqués."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vigye az egeret a menüsor üres területére a rejtett menüsor elemek megjelenítéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arahkan kursor ke area kosong bar menu untuk menampilkan item bar menu tersembunyi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passa il mouse su un'area vuota della barra dei menu per visualizzare gli elementi nascosti della barra dei menu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーの空いている領域にカーソルを合わせると、非表示のメニューバー項目が表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메뉴 막대의 빈 영역 위에 마우스를 올려 숨겨진 메뉴 막대 항목을 표시합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beweeg de muis over een leeg gedeelte van de menubalk om verborgen menu-items weer te geven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Umieść kursor nad pustym miejscem na pasku menu, by zobaczyć ukryte opcje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passe o cursor sobre uma área vazia da barra de menus para mostrar os itens ocultos da barra de menus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Наведите курсор на пустую область строки меню, чтобы показать скрытые элементы."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "วางเมาส์เหนือพื้นที่ว่างบนแถบเมนูเพื่อแสดงรายการซ่อนอยู่"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gizli menü çubuğu öğelerini göstermek için menü çubuğunda boş bir alanın üzerine gelin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Наведіть курсор на порожню ділянку рядка меню, щоб показати приховані об'єкти."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Di chuột qua vùng trống của thanh menu để hiển thị các mục thanh menu ẩn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
