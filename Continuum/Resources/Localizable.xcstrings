          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elrendezés visszaállítva. Az elemek a Rejtett szakaszba kerültek."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tata Letak diatur ulang. Item dipindahkan ke Bagian Tersembunyi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Layout ripristinato. Gli elementi sono stati spostati nella sezione Nascosti."
