    "Show the %@ icon in the menu bar. Click to show hidden items and right-click for settings." : {

    },
    "Show the %@ icon in the menu bar. Click to show hidden items, double-click for always-hidden, and right-click for settings." : {
      "comment" : "Toggle that lets the user decide whether to show the \\(Constants.displayName) icon in the menu bar.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zobrazit ikonu %@ v řádku nabídek. Kliknutím zobrazíte skryté položky, dvojitým kliknutím trvale skryté položky a kliknutím pravým tlačítkem myši otevřete nastavení."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeige das %@-Symbol in der Menüleiste. Klicken um versteckte Einträge anzuzeigen, doppelklicken um immer versteckte Einträge und rechtsklicken um die Einstellungen anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostrar el ícono de %@ en la barra de menús. Haz clic para mostrar los elementos ocultos, doble clic para los siempre ocultos, y clic derecho para los ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Affiche l'icône %@ dans la barre des menus. Cliquez une fois pour afficher les éléments masqués, double-cliquez pour afficher les éléments toujours cachés, et faites un clic droit pour accéder aux réglages."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A %@ ikon megjelenítése a menüsávban. Kattintás a rejtett elemek megjelenítéséhez, dupla kattintás a mindig rejtett elemekhez, jobb kattintás a beállításokhoz."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tampilkan ikon %@ di bar menu. Klik untuk menampilkan item tersembunyi, klik dua kali untuk item selalu-tersembunyi, dan klik kanan untuk membuka pengaturan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostra l'icona %@ nella barra dei menu. Fai clic per mostrare gli elementi nascosti, fai doppio clic per renderli sempre nascosti e fai clic con il pulsante destro del mouse per le impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーに %@ アイコンを表示します。クリックで非表示項目を表示、ダブルクリックで常に非表示の項目を表示、右クリックで設定を開きます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메뉴 막대에 %@ 아이콘을 표시합니다. 클릭하면 숨겨진 항목이 표시되고, 더블 클릭하면 항상 숨겨진 항목이 표시되며, 오른쪽 클릭하면 설정이 열립니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geef het %@-pictogram weer in de menubalk. Klik erop om verborgen items weer te geven, dubbelklik om ze permanent te verbergen en klik met de rechtermuisknop voor instellingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokaż ikonę %@ na pasku menu. Kliknij, by wyświetlić ukryte ikony; kliknij dwukrotnie dla stale ukrytych; kliknij prawym przyciskiem, by otworzyć ustawienia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mostrar o ícone %@ na barra de menus. Clique para mostrar itens ocultos, clique duas vezes para Sempre Ocultos e clique com o botão direito para acessar as configurações."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Показывать значок %@ в строке меню. Нажмите, чтобы показать скрытые элементы, дважды нажмите для всегда скрытых, правый клик для настроек."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แสดงไอคอน %@ ในแถบเมนู คลิกเพื่อแสดงรายการที่ซ่อนไว้ ดับเบิลคลิกสำหรับซ่อนไว้เสมอ และคลิกขวาเพื่อตั้งค่า"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menü çubuğunda %@ simgesini göster. Gizli öğeleri göstermek için tıklayın, her zaman gizli için çift tıklayın, ayarlar için sağ tıklayın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Показувати значок %@ у рядку меню. Натискання показує приховані об'єкти, подвійне натискання — завжди приховані, а праве натискання відкриває налаштування."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hiển thị biểu tượng %@ trên thanh menu. Nhấp để hiển thị các mục bị ẩn, nhấp đúp để luôn ẩn và nhấp chuột phải để cài đặt."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在菜单栏显示 %@ 图标。单击显示隐藏项目，双击显示永久隐藏的项目，右键单击打开设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在選單列中顯示 %@ 圖示。按一下以顯示隱藏項目，按兩下以顯示永久隱藏項目，按右鍵以開啟設定。"
          }
        }
      }
    },
