    "Double-click %@ icon to open always-hidden section" : {
      "comment" : "A toggle that lets the user enable or disable the option of using double-clicking the app icon to open the always-hidden section.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otevřít sekci „Trvale skryté“ dvojitým poklepáním na ikonu %@"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@-Symbol doppelklicken, um den Immer-Versteckt-Bereich anzuzeigen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz doble clic en el icono %@ para abrir la sección que siempre está oculta"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Double-cliquez sur l'icône %@ pour ouvrir la section cachée"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kattints duplán a %@ ikonra a mindig rejtett szakasz megnyitásához"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik dua kali ikon %@ untuk membuka bagian selalu-tersembunyi"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doppio click sull'icona %@ per aprire la sezione sempre nascosto"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ アイコンをダブルクリックして常に非表示セクションを開く"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 아이콘을 더블 클릭하여 항상 숨김 섹션을 열기"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dubbelklik op het %@-pictogram om het altijd verborgen gedeelte te openen"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknij dwukrotnie ikonę %@, aby otworzyć zawsze ukrytą sekcję"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duplo clique no ícone %@ para abrir a seção Sempre Ocultos"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дважды щелкните значок %@, чтобы открыть скрытый раздел"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ดับเบิลคลิกไอคอน %@ เพื่อเปิดส่วนที่ถูกซ่อนตลอดเวลา"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her zaman gizli bölümünü açmak için %@ ikonunu iki kez tıkla"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Double-click %@ icon to open always-hidden section"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bấm đúp vào biểu tượng %@ để mở phần luôn bị ẩn"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "双击 %@ 图标以打开始终隐藏区域。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按兩下 %@ 圖示以開啟永遠隱藏區段"
          }
        }
      }
    },
    "Double-click an empty area of the menu bar to show always-hidden menu bar items." : {
      "comment" : "Toggle that allows users to enable or disable the feature of showing always-hidden menu bar items by double-clicking an empty area of the menu bar.",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikony v sekci „Trvale skryté“  zobrazíte dvojitým poklepáním na prázdné místo v řádku nabídek"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einen leeren Bereich der Menüleiste doppelt anklicken, um immer versteckte Menüleisten-Einträge anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz doble clic en un área vacía de la barra de menús para mostrar los elementos siempre ocultos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Double-cliquez dans une zone vide de la barre des menus pour afficher les éléments toujours cachés."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kattints duplán a menüsáv egy üres területére a mindig rejtett menüsávelemek megjelenítéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik area kosong bar menu untuk menampilkan item bar menu selalu-tersembunyi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fare doppio clic su un'area vuota della barra dei menu per visualizzare le voci della barra dei menu sempre nascoste."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーの空いている領域をダブルクリックすると、常に非表示のメニューバー項目が表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메뉴 막대의 빈 공간을 더블 클릭하면 항상 숨겨진 메뉴 막대 항목이 표시됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dubbelklik op een leeg gedeelte van de menubalk om de standaard verborgen menu-items weer te geven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknij dwukrotnie pusty obszar paska menu, aby wyświetlić zawsze ukryte elementy paska menu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique duas vezes em uma área vazia da barra de menus para exibir os itens sempre ocultos da barra de menus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дважды нажмите на пустую область строки меню, чтобы показать всегда скрытые элементы."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ดับเบิลคลิกบริเวณว่างของแถบเมนูเพื่อแสดงรายการแถบเมนูที่ซ่อนอยู่เสมอ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her zaman gizli menü çubuğu öğelerini göstermek için menü çubuğunda boş bir alana çift tıklayın."
          }
