          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Об'єкти також можна впорядковувати, перетягуючи їх у рядку меню з утриманою клавішею ⌘ Command."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
